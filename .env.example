# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME="cPanel Manager"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://votre-panel.example.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

# Coût bcrypt (min recommandé en production : 12)
BCRYPT_ROUNDS=12

# ─────────────────────────────────────────────────────────────────────────────
# LOGS
# ─────────────────────────────────────────────────────────────────────────────
LOG_CHANNEL=daily
LOG_LEVEL=warning

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DONNÉES
# ─────────────────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cpanelmanager
DB_USERNAME=db_user
DB_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# SESSION
# ─────────────────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# ─────────────────────────────────────────────────────────────────────────────
# CACHE
# ─────────────────────────────────────────────────────────────────────────────
CACHE_STORE=database

# ─────────────────────────────────────────────────────────────────────────────
# FILE SYSTEM / QUEUE
# ─────────────────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# ─────────────────────────────────────────────────────────────────────────────
# CPANEL API
# Générer un Personal Access Token dans : cPanel > Sécurité > Tokens API
# ATTENTION : ne jamais committer CPANEL_TOKEN
# ─────────────────────────────────────────────────────────────────────────────

# Hôte du serveur (sans https:// ni port)
CPANEL_HOST=votre-serveur.example.com

# Port de connexion (2083 = cPanel SSL)
CPANEL_PORT=2083

# Nom d'utilisateur du compte cPanel principal
CPANEL_USERNAME=nom_du_compte

# Personal Access Token (généré dans cPanel)
CPANEL_TOKEN=

# Mot de passe du compte cPanel (optionnel)
# Si défini, la connexion manuelle proxiée par Laravel l'utilise automatiquement
# sans que l'utilisateur ait à saisir son mot de passe dans le navigateur.
CPANEL_PASSWORD=

# Domaine principal du compte (utilisé comme valeur par défaut dans les formulaires)
CPANEL_DOMAIN=example.com

# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH 2.0
# Console Google Cloud → API et services → Identifiants → ID client OAuth 2.0
# Type : Application Web
# URI de redirection : https://votre-panel.example.com/auth/google/callback
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://votre-panel.example.com/auth/google/callback

# ─────────────────────────────────────────────────────────────────────────────
# SUPER ADMINISTRATEUR INITIAL
# Utilisé uniquement lors du premier `php artisan db:seed`
# Connexion exclusivement via Google OAuth.
# ─────────────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=maxime.ponsart@groupe-speed.cloud
ADMIN_NAME="Maxime Ponsart"

# Forcer d'autres super admins (emails séparés par des virgules)
# Ex: FORCE_SUPER_ADMINS=maxime.ponsart@groupe-speed.cloud,autre@exemple.com
FORCE_SUPER_ADMINS=

# ─────────────────────────────────────────────────────────────────────────────
# MONASSO
# Chemin absolu vers le répertoire contenant les dossiers des associations
# ─────────────────────────────────────────────────────────────────────────────
MONASSO_PATH=/home/gowo3083/monasso

# ─────────────────────────────────────────────────────────────────────────────
# TERMINAL SSH
# Utilisé pour le terminal web intégré (permission : use_terminal)
# SSH_HOST     : hôte SSH (défaut : CPANEL_HOST)
# SSH_PORT     : port SSH (défaut : 22)
# SSH_USERNAME : utilisateur SSH (défaut : CPANEL_USERNAME)
# SSH_KEY_PATH : chemin absolu vers la clé privée SSH
#                Ex : /home/nom_du_compte/.ssh/id_rsa
# ─────────────────────────────────────────────────────────────────────────────
SSH_HOST=
SSH_PORT=22
SSH_USERNAME=
SSH_KEY_PATH=
